#!/usr/bin/env bash
# Init script to start, stop, and restart manage_my_process

PIDFILE="/var/run/my_process.pid"
DAEMON="./manage_my_process"

start() {
    $DAEMON &
    echo $! > "$PIDFILE"
}

stop() {
    if [ -f "$PIDFILE" ]; then
        kill "$(cat "$PIDFILE")" 2>/dev/null
        rm -f "$PIDFILE"
    else
        echo "PID file not found. Is the process running?" >&2
        exit 1
    fi
}

case "$1" in
    start)
        start
        echo "manage_my_process started"
        ;;
    stop)
        stop
        echo "manage_my_process stopped"
        ;;
    restart)
        stop
        sleep 1
        start
        echo "manage_my_process restarted"
        ;;
    *)
        echo "Usage: manage_my_process {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
